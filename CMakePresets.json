{
  "version": 4,
  "configurePresets": [
    {
      "name": "base-win",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {"name": "tls-none", "hidden": true, "cacheVariables": {"MGXX_TLS": "none"}},
    {"name": "tls-builtin", "hidden": true, "cacheVariables": {"MGXX_TLS": "builtin"}},
    {"name": "tls-openssl", "hidden": true, "cacheVariables": {"MGXX_TLS": "openssl"}},
    {"name": "tls-mbedtls", "hidden": true, "cacheVariables": {"MGXX_TLS": "mbedtls"}},

    {"name": "examples", "hidden": true, "cacheVariables": {"MGXX_BUILD_EXAMPLES_DEFAULT": "ON"}},
    {"name": "no-examples", "hidden": true, "cacheVariables": {"MGXX_BUILD_EXAMPLES_DEFAULT": "OFF"}},

    {"name": "lib-win", "displayName": "Static Library", "inherits": ["base-win", "tls-none", "no-examples"]},
    {"name": "lib-win-tls", "displayName": "Static Library w/ TLS builtin", "inherits": ["base-win", "tls-builtin", "no-examples"]},
    {"name": "lib-win-openssl", "displayName": "Static Library w/ OpenSSL", "inherits": ["base-win", "tls-openssl", "no-examples"]},
    {"name": "lib-win-mbedtls", "displayName": "Static Library w/ Mbed-TLS", "inherits": ["base-win", "tls-mbedtls", "no-examples"]},

    {"name": "examples-win", "displayName": "Examples", "inherits": ["base-win", "tls-none", "examples"]},
    {"name": "examples-win-tls", "displayName": "Examples w/ TLS builtin", "inherits": ["base-win", "tls-builtin", "examples"]},
    {"name": "examples-win-openssl", "displayName": "Examples w/ OpenSSL", "inherits": ["base-win", "tls-openssl", "examples"]},
    {"name": "examples-win-mbedtls", "displayName": "Examples w/ Mbed-TLS", "inherits": ["base-win", "tls-mbedtls", "examples"]}
  ],
  "buildPresets": []
}