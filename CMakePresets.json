{
  "version": 4,
  "configurePresets": [
    {
      "name": "base-win",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {"name": "tls-none", "hidden": true, "cacheVariables": {"MGPP_TLS": "none"}},
    {"name": "tls-builtin", "hidden": true, "cacheVariables": {"MGPP_TLS": "builtin"}},
    {"name": "tls-openssl", "hidden": true, "cacheVariables": {"MGPP_TLS": "openssl"}},
    {"name": "tls-mbedtls", "hidden": true, "cacheVariables": {"MGPP_TLS": "mbedtls"}},
    {"name": "tls-wolfssl", "hidden": true, "cacheVariables": {"MGPP_TLS": "wolfssl"}},

    {"name": "example", "hidden": true, "cacheVariables": {"BUILD_EXAMPLES": "ON"}},
    {"name": "no-example", "hidden": true, "cacheVariables": {"BUILD_EXAMPLES": "OFF"}},

    {"name": "lib-win", "displayName": "Static Library", "inherits": ["base-win", "tls-none", "no-example"]},
    {"name": "lib-win-tls", "displayName": "Static Library w/ TLS builtin", "inherits": ["base-win", "tls-builtin", "no-example"]},
    {"name": "lib-win-openssl", "displayName": "Static Library w/ OpenSSL", "inherits": ["base-win", "tls-openssl", "no-example"]},
    {"name": "lib-win-mbedtls", "displayName": "Static Library w/ Mbed-TLS", "inherits": ["base-win", "tls-mbedtls", "no-example"]},
    {"name": "lib-win-wolfssl", "displayName": "Static Library w/ wolfSSL", "inherits": ["base-win", "tls-wolfssl", "no-example"]},

    {"name": "example-win", "displayName": "Example", "inherits": ["base-win", "tls-none", "example"]},
    {"name": "example-win-tls", "displayName": "Example w/ TLS builtin", "inherits": ["base-win", "tls-builtin", "example"]},
    {"name": "example-win-openssl", "displayName": "Example w/ OpenSSL", "inherits": ["base-win", "tls-openssl", "example"]},
    {"name": "example-win-mbedtls", "displayName": "Example w/ Mbed-TLS", "inherits": ["base-win", "tls-mbedtls", "example"]},
    {"name": "example-win-wolfssl", "displayName": "Example w/ wolfSSL", "inherits": ["base-win", "tls-wolfssl", "example"]}
  ],
  "buildPresets": []
}